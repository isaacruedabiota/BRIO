# Copy this file to `.env` and fill in your own values. Never commit `.env`.

# Which settings module to load: config.settings.development | config.settings.production
DJANGO_SETTINGS_MODULE=config.settings.development

# Django secret key — generate a fresh, random one (e.g. with
# `python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"`).
SECRET_KEY=change-me-generate-a-random-secret-key

# ── Production only (read by config/settings/production.py) ──────────────────
# Comma-separated hosts/domains the backend is served on.
ALLOWED_HOSTS=yourdomain.example.com,127.0.0.1,localhost
# Origins allowed for CSRF (needed to reach /admin over HTTPS).
CSRF_TRUSTED_ORIGINS=https://yourdomain.example.com
